      {
        "id": 10,
        "title": "🏆 コストランキング (累計 USD)",
        "type": "table",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 10
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 3
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "user_email"
              },
              "properties": [
                {
                  "id": "displayName",
                  "value": "ユーザー"
                },
                {
                  "id": "custom.width",
                  "value": 180
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "Value"
              },
              "properties": [
                {
                  "id": "displayName",
                  "value": "コスト"
                },
                {
                  "id": "custom.displayMode",
                  "value": "color-background"
                },
                {
                  "id": "thresholds",
                  "value": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "green",
                        "value": null
                      },
                      {
                        "color": "yellow",
                        "value": 1
                      },
                      {
                        "color": "red",
                        "value": 3
                      }
                    ]
                  }
                }
              ]
            }
          ]
        },
        "options": {
          "sortBy": [
            {
              "displayName": "コスト",
              "desc": true
            }
          ],
          "footer": {
            "show": true,
            "reducer": [
              "sum"
            ],
            "fields": "Value"
          }
        },
        "transformations": [
          {
            "id": "labelsToFields",
            "options": {
              "valueLabel": "user_email",
              "mode": "columns"
            }
          },
          {
            "id": "sortBy",
            "options": {
              "fields": [
                {
                  "displayName": "Value",
                  "desc": true
                }
              ]
            }
          }
        ],
        "targets": [
          {
            "refId": "A",
            "expr": "sum by (user_email) (claude_code_cost_usage_USD_total{user_email=~\"$user\"})",
            "instant": true,
            "legendFormat": "{{user_email}}"
          }
        ]
      },
