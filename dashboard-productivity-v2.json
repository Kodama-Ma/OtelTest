{
  "dashboard": {
    "uid": "claude-code-productivity-v2",
    "title": "Claude Code Productivity v2",
    "tags": [
      "claude-code",
      "productivity"
    ],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 0,
    "refresh": "30s",
    "time": {
      "from": "now-7d",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "user",
          "label": "User",
          "type": "query",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "query": {
            "query": "label_values(claude_code_session_count_total, user_email)",
            "refId": "A"
          },
          "includeAll": true,
          "multi": true,
          "current": {
            "text": "All",
            "value": "$__all"
          },
          "refresh": 2
        },
        {
          "name": "model",
          "label": "Model",
          "type": "query",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "query": {
            "query": "label_values(claude_code_token_usage_tokens_total, model)",
            "refId": "B"
          },
          "includeAll": true,
          "multi": true,
          "current": {
            "text": "All",
            "value": "$__all"
          },
          "refresh": 2
        }
      ]
    },
    "panels": [
      {
        "id": 70,
        "title": "👥 アクティブユーザー数 (DAU相当)",
        "type": "stat",
        "gridPos": {
          "h": 3,
          "w": 6,
          "x": 0,
          "y": 0
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "テレメトリを送信しているユニークユーザー数。DAU の代替指標（日次集計は時間範囲を1dに変更）。",
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {
              "mode": "fixed",
              "fixedColor": "blue"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 3
                },
                {
                  "color": "green",
                  "value": 5
                }
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "background"
        },
        "targets": [
          {
            "refId": "A",
            "expr": "count(count by (user_email) (claude_code_session_count_total{user_email=~\"$user\"}))",
            "instant": true
          }
        ]
      },
      {
        "id": 71,
        "title": "🔄 resume率 (会話継続率)",
        "type": "gauge",
        "gridPos": {
          "h": 3,
          "w": 6,
          "x": 6,
          "y": 0
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "全セッションのうち前の会話を引き継いだ割合。30%以上が健全。高いほど文脈を活かして使えている。",
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 0.2
                },
                {
                  "color": "green",
                  "value": 0.3
                }
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          }
        },
        "targets": [
          {
            "refId": "A",
            "expr": "sum(claude_code_session_count_total{start_type=\"resume\",user_email=~\"$user\"}) / sum(claude_code_session_count_total{user_email=~\"$user\"})",
            "instant": true
          }
        ]
      },
      {
        "id": 72,
        "title": "📊 モデル別コスト内訳",
        "type": "piechart",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 0
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "Opus/Sonnet/Haiku のコスト比率。Opus が 60% 超なら最適化余地あり（単純作業に Sonnet で十分）。",
        "options": {
          "pieType": "donut",
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "values": [
              "value",
              "percent"
            ]
          }
        },
        "targets": [
          {
            "refId": "A",
            "expr": "sum by (model) (claude_code_cost_usage_USD_total{user_email=~\"$user\"})",
            "legendFormat": "{{model}}",
            "instant": true
          }
        ]
      },
      {
        "id": 73,
        "title": "⚠️ APIエラー発生数",
        "type": "stat",
        "gridPos": {
          "h": 3,
          "w": 6,
          "x": 18,
          "y": 0
        },
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "description": "api_error イベントの累計数。急増したらネットワーク障害またはレート制限を疑う。",
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "noValue": "0",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 5
                },
                {
                  "color": "red",
                  "value": 20
                }
              ]
            },
            "color": {
              "mode": "thresholds"
            }
          }
        },
        "options": {
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          },
          "colorMode": "background"
        },
        "targets": [
          {
            "refId": "A",
            "expr": "sum(count_over_time({service_name=\"claude-code\", event_name=\"api_error\"}[$__range])) or vector(0)"
          }
        ]
      },
      {
        "id": 74,
        "title": "🔄 resume率ランキング (会話継続率 by ユーザー)",
        "type": "barchart",
        "gridPos": {
          "h": 7,
          "w": 12,
          "x": 0,
          "y": 4
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "ユーザー別の resume 率。高いほど会話の文脈を活かして連続作業できている。低いユーザーは fresh ばかり → セッション引き継ぎを促す。",
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 0.2
                },
                {
                  "color": "green",
                  "value": 0.3
                }
              ]
            },
            "custom": {
              "displayMode": "color-background"
            }
          }
        },
        "options": {
          "orientation": "horizontal",
          "xTickLabelRotation": 0,
          "legend": {
            "displayMode": "hidden"
          }
        },
        "targets": [
          {
            "refId": "A",
            "expr": "sum by (user_email) (claude_code_session_count_total{start_type=\"resume\",user_email=~\"$user\"}) / sum by (user_email) (claude_code_session_count_total{user_email=~\"$user\"})",
            "legendFormat": "{{user_email}}",
            "instant": true
          }
        ]
      },
      {
        "id": 75,
        "title": "🧮 cacheRead率ランキング (キャッシュ活用率)",
        "type": "barchart",
        "gridPos": {
          "h": 7,
          "w": 12,
          "x": 12,
          "y": 4
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "cacheRead / 総トークンの比率。高いほどプロンプトキャッシュが効いており低コスト・高速。70% 以上が目標。低いユーザーは毎回新規セッション or プロンプト先頭が毎回変わっている。",
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 0.5
                },
                {
                  "color": "green",
                  "value": 0.7
                }
              ]
            },
            "custom": {
              "displayMode": "color-background"
            }
          }
        },
        "options": {
          "orientation": "horizontal",
          "legend": {
            "displayMode": "hidden"
          }
        },
        "targets": [
          {
            "refId": "A",
            "expr": "sum by (user_email) (claude_code_token_usage_tokens_total{type=\"cacheRead\",user_email=~\"$user\"}) / sum by (user_email) (claude_code_token_usage_tokens_total{user_email=~\"$user\"})",
            "legendFormat": "{{user_email}}",
            "instant": true
          }
        ]
      },
      {
        "id": 1,
        "title": "セッション数",
        "type": "stat",
        "gridPos": {
          "h": 3,
          "w": 4,
          "x": 0,
          "y": 7
        },
        "datasource": {
          "type": "prometheus",
