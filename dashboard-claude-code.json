{
  "dashboard": {
    "uid": "claude-code-otel",
    "title": "Claude Code Usage (OTel)",
    "tags": ["claude-code", "otel"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 0,
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "templating": {
      "list": [
        {
          "name": "model",
          "label": "Model",
          "type": "query",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "query": { "query": "label_values(claude_code_token_usage_tokens_total, model)", "refId": "A" },
          "includeAll": true,
          "multi": true,
          "current": { "text": "All", "value": "$__all" }
        }
      ]
    },
    "panels": [
      {
        "id": 1, "title": "Total Cost (USD)", "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4, "color": { "mode": "fixed", "fixedColor": "green" } } },
        "targets": [ { "refId": "A", "expr": "sum(claude_code_cost_usage_USD_total)" } ]
      },
      {
        "id": 2, "title": "Total Tokens", "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } },
        "targets": [ { "refId": "A", "expr": "sum(claude_code_token_usage_tokens_total{model=~\"$model\"})" } ]
      },
      {
        "id": 3, "title": "Sessions", "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "purple" } } },
        "targets": [ { "refId": "A", "expr": "sum(claude_code_session_count_total)" } ]
      },
      {
        "id": 4, "title": "Active Time (s)", "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": { "defaults": { "unit": "s", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "orange" } } },
        "targets": [ { "refId": "A", "expr": "sum(claude_code_active_time_seconds_total)" } ]
      },
      {
        "id": 5, "title": "Tokens by Type", "type": "piechart",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value"] }, "pieType": "donut" },
        "targets": [ { "refId": "A", "expr": "sum by (type) (claude_code_token_usage_tokens_total{model=~\"$model\"})", "legendFormat": "{{type}}", "instant": true } ]
      },
      {
        "id": 6, "title": "Token Usage Rate", "type": "timeseries",
        "gridPos": { "h": 8, "w": 16, "x": 8, "y": 4 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 15, "stacking": { "mode": "normal" } } } },
        "targets": [ { "refId": "A", "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total{model=~\"$model\"}[$__rate_interval]))", "legendFormat": "{{type}}" } ]
      },
      {
        "id": 7, "title": "Cumulative Cost (USD)", "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4, "custom": { "drawStyle": "line", "fillOpacity": 20 } } },
        "targets": [ { "refId": "A", "expr": "sum by (model) (claude_code_cost_usage_USD_total)", "legendFormat": "{{model}}" } ]
      },
      {
        "id": 8, "title": "Tokens by Model", "type": "barchart",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": { "defaults": { "unit": "short" } },
        "targets": [ { "refId": "A", "expr": "sum by (model) (claude_code_token_usage_tokens_total)", "legendFormat": "{{model}}", "instant": true } ]
      },
      {
        "id": 9, "title": "Events (Loki)", "type": "logs",
        "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
        "datasource": { "type": "loki", "uid": "loki" },
        "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "sortOrder": "Descending" },
        "targets": [ { "refId": "A", "expr": "{service_name=\"claude-code\"}" } ]
      }
    ]
  },
  "overwrite": true
}
