# =============================================================================
# Claude Code -> OpenTelemetry (Grafana LGTM) 連携用 環境変数
# =============================================================================
# 使い方:
#   source ./claude-otel.env
#   claude
# これで現在のシェルから起動した Claude Code のテレメトリが
# ローカルの LGTM スタック (docker-compose) に送信されます。
# -----------------------------------------------------------------------------

# 1) テレメトリ収集を有効化（必須）
export CLAUDE_CODE_ENABLE_TELEMETRY=1

# 2) エクスポータの選択（メトリクスとログ/イベント）
export OTEL_METRICS_EXPORTER=otlp
export OTEL_LOGS_EXPORTER=otlp

# 3) OTLP の送信先（LGTM の OTel Collector）
#    gRPC(4317) を使用。HTTP にしたい場合は下のコメント参照
export OTEL_EXPORTER_OTLP_PROTOCOL=grpc
export OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# 3.5) ★重要★ temporality を cumulative にする
#    Claude Code はデフォルト delta 送信だが、LGTM(Prometheus) は cumulative を
#    期待するため、delta のままだとメトリクスが Prometheus に出てこない。
export OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=cumulative

# 4) 検証時はエクスポート間隔を短くして反映を早める
#    （本番運用ではデフォルトに戻すこと: metrics 60000 / logs 5000）
export OTEL_METRIC_EXPORT_INTERVAL=10000   # 10秒
export OTEL_LOGS_EXPORT_INTERVAL=5000      # 5秒

# 5) 識別用のサービス名（Grafana 上で絞り込みやすくする）
export OTEL_SERVICE_NAME=claude-code
export OTEL_RESOURCE_ATTRIBUTES=service.namespace=local-verify,deployment.environment=local

# -----------------------------------------------------------------------------
# （任意）トレース(beta)も見たい場合は以下を有効化:
# export CLAUDE_CODE_ENHANCED_TELEMETRY_BETA=1
# export OTEL_TRACES_EXPORTER=otlp
#
# （任意）HTTP/protobuf で送る場合は 2)〜3) を下記に置き換え:
# export OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# export OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# -----------------------------------------------------------------------------
